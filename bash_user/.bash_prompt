# --- Hostname Alias Configuration ---
# Hybrid alias system: dictionary + /etc/hosts fallback

HOSTNAME_ALIASES=(
    "wawsrvdev175:dev"
    "wawsrvdev174:DM_stg"
    "wawsrvdev124:DM_dev"
    "wawsrvdev125:DM_dev2"
    "wawsrvdev126:DM_ldap"
    "wawsrvdev127:DM_dev3"
    "wawsrvdev128:DM_dev4"
    "wawsrvbuild100:DM_dev5"
    "wawsrvbuild102:DM_dev6"
    "wawsrvbuild103:DM_dev7"
)

get_hostname_alias() {
    local hostname=$(hostname)
    local short_hostname=${hostname%%.*}
    local host_alias

    # ~/.hostname.alias takes priority - single line, just the alias value
    if [[ -r ~/.hostname.alias ]]; then
        host_alias=$(grep -m1 '[^[:space:]]' ~/.hostname.alias 2>/dev/null)
        [[ -n "$host_alias" ]] && { echo "$host_alias"; return; }
    fi

    # Fallback to built-in array
    for mapping in "${HOSTNAME_ALIASES[@]}"; do
        if [[ $mapping == $short_hostname:* ]]; then
            echo "${mapping#*:}"
            return
        fi
    done

    # Fallback to /etc/hosts
    if [[ -r /etc/hosts ]]; then
        host_alias=$(grep -E "^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+.*\b${hostname}\b" /etc/hosts 2>/dev/null | \
            awk -v host="$hostname" -v short_host="$short_hostname" '{
                for(i=2; i<=NF; i++) {
                    if($i != host && $i != short_host) {
                        print $i
                        exit
                    }
                }
            }')
        if [[ -n "$host_alias" && "$host_alias" != "$hostname" && "$host_alias" != "$short_hostname" ]]; then
            echo "$host_alias"
            return
        fi
    fi

    # Default to short hostname
    echo "$short_hostname"
}

# --- Colors ---
RESET='\[\e[0m\]'
BOLD='\[\e[1m\]'
DIM='\[\e[2m\]'
CYAN='\[\e[36m\]'
GREEN='\[\e[32m\]'
YELLOW='\[\e[33m\]'
RED='\[\e[31m\]'
MAGENTA='\[\e[35m\]'

# --- Git segment ---
_git_segment() {
    GIT_OPTIONAL_LOCKS=0 git rev-parse --is-inside-work-tree &>/dev/null || return

    # Branch / ref
    local ref
    ref=$(git symbolic-ref --short -q HEAD 2>/dev/null \
        || git describe --tags --exact-match 2>/dev/null \
        || git rev-parse --short HEAD 2>/dev/null)
    [ -z "$ref" ] && return

    # Porcelain status (fast to parse)
    local s
    s=$(git status --porcelain 2>/dev/null)

    # Counters
    local staged unstaged untracked conflicts stashed
    staged=$(printf '%s\n' "$s" | grep -cE '^[MADRC]' || true)   # X = M/A/D/R/C → staged
    unstaged=$(printf '%s\n' "$s" | grep -cE '^.[MD]' || true)   # Y = M/D → worktree changes
    untracked=$(printf '%s\n' "$s" | grep -cE '^\?\?' || true)
    conflicts=$(printf '%s\n' "$s" | grep -cE '^(DD|AU|UD|UA|DU|AA|UU)' || true) # all 7 unmerged states
    if git rev-parse --verify -q refs/stash >/dev/null; then stashed=1; else stashed=0; fi

    # Build status tokens
    local tokens=""
    if [ "$staged" -gt 0 ]; then tokens+=" ${GREEN}+${staged}${RESET}"; fi
    if [ "$unstaged" -gt 0 ]; then tokens+=" ${YELLOW}~${unstaged}${RESET}"; fi
    if [ "$untracked" -gt 0 ]; then tokens+=" ${MAGENTA}?${untracked}${RESET}"; fi
    if [ "$conflicts" -gt 0 ]; then tokens+=" ${RED}!${conflicts}${RESET}"; fi
    if [ "$stashed" -gt 0 ]; then tokens+=" ${DIM}≡${RESET}"; fi

    # Clean mark if no changes
    if [ "$staged" -eq 0 ] && [ "$unstaged" -eq 0 ] && [ "$untracked" -eq 0 ] && [ "$conflicts" -eq 0 ]; then
        tokens+=" ${GREEN}✔${RESET}"
    fi

    printf " (%s%s%s)" "${CYAN}" "$ref" "${RESET}${tokens}"
}

# --- Prompt builder ---
_HOSTNAME_ALIAS=""

_build_ps1() {
    local git="$(_git_segment)"
    [[ -z "$_HOSTNAME_ALIAS" ]] && _HOSTNAME_ALIAS=$(get_hostname_alias)

    printf '\033]0;%s@%s\007' "$USER" "$_HOSTNAME_ALIAS"

    if [[ $PWD == "$HOME" ]]; then
        PS1="${GREEN}\u${RESET}@${MAGENTA}${_HOSTNAME_ALIAS}${RESET}\n${CYAN}~${RESET}${git}"' \$ '
    else
        PS1="${CYAN}\w${RESET}${git}"' \$ '
    fi
}

# Set prompt command
PROMPT_COMMAND=_build_ps1
